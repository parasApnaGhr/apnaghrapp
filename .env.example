# Root sample environment file for local development.
# The backend loads from backend/.env, but this file documents the values
# the project currently references across backend and frontend code.

# =========================
# Backend
# =========================

# MongoDB
MONGO_URL=mongodb://localhost:27017/apnaghr
# Optional aliases supported by backend code
MONGODB_URL=
MONGODB_URI=

# JWT
JWT_SECRET=change-this-secret

# Cashfree
CASHFREE_APP_ID=
CASHFREE_SECRET_KEY=
CASHFREE_ENVIRONMENT=SANDBOX

# Notifications
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
RESEND_API_KEY=
SENDER_EMAIL=onboarding@resend.dev

# AI / platform integrations
EMERGENT_LLM_KEY=
OPENAI_API_KEY=
GOOGLE_API_KEY=
GEMINI_API_KEY=

# Optional storage and app settings
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=
AWS_S3_BUCKET=
APP_BASE_URL=http://localhost:8001

# =========================
# Frontend
# =========================

# Create React App variables must be prefixed with REACT_APP_
REACT_APP_BACKEND_URL=http://localhost:8001
